{
  "language": "rust",
  "ident": {
    "keywords": [
      "as",
      "async",
      "await",
      "box",
      "break",
      "const",
      "continue",
      "crate",
      "dyn",
      "else",
      "enum",
      "extern",
      "false",
      "fn",
      "for",
      "if",
      "impl",
      "in",
      "let",
      "loop",
      "match",
      "mod",
      "move",
      "mut",
      "pub",
      "ref",
      "return",
      "static",
      "struct",
      "super",
      "trait",
      "true",
      "type",
      "unsafe",
      "use",
      "where",
      "while",
      "abstract",
      "become",
      "do",
      "final",
      "macro",
      "override",
      "priv",
      "try",
      "typeof",
      "unsized",
      "virtual",
      "yield",
      "union"
    ],
    "no_raw": [
      "self",
      "Self",
      "super",
      "crate"
    ],
    "remap": {
      "_": "blank",
      "": "field"
    },
    "escape": {
      "style": "prefix",
      "with": "r#"
    },
    "reserved_type_names": [
      "Vec",
      "String",
      "Option",
      "Result",
      "Box",
      "Rc",
      "Arc",
      "HashMap",
      "HashSet",
      "BTreeMap",
      "BTreeSet",
      "Cow",
      "Cell",
      "RefCell",
      "Some",
      "None",
      "Ok",
      "Err"
    ],
    "reserve_root_name": false,
    "reserve_alias_names": false
  },
  "types": {
    "strip_leading": "*",
    "simple": {
      "str": "String",
      "bytes": "Vec<u8>",
      "bool": "bool",
      "i64": "i64",
      "f64": "f64",
      "unit": "()",
      "any": "serde_json::Value",
      "error": "String",
      "fn": "serde_json::Value"
    },
    "containers": {
      "list": {
        "format": "Vec<{0}>"
      },
      "iter": {
        "format": "Vec<{0}>"
      },
      "map": {
        "format": "std::collections::HashMap<{0}, {1}>",
        "defaults": [
          "any",
          "any"
        ]
      },
      "set": {
        "format": "std::collections::HashSet<{0}>"
      },
      "option": {
        "format": "Option<{0}>"
      },
      "result": {
        "format": "Result<{0}, {1}>",
        "defaults": [
          "any",
          "error"
        ]
      },
      "tuple": {
        "variadic": true,
        "format": "({args})",
        "join": ", ",
        "empty": "()"
      }
    },
    "fallback": "serde_json::Value"
  },
  "templates": {
    "module_sep": "::",
    "base_indent": "",
    "ctx_binding": "__ctx",
    "header": [
      "#![allow(dead_code, unused_variables, unused_mut, non_snake_case, unused_imports)]",
      "//! Generated by SPIndlebox ${version} from project '${project}'. Bodies are todo!() stubs.",
      "",
      "#[derive(Debug)]",
      "pub enum OpError {",
      "    MissingCtxKey(&'static str),",
      "    Todo,",
      "}",
      "",
      "#[derive(Default, Debug)]",
      "pub struct Ctx {"
    ],
    "ctx_field": "    pub ${field}: Option<${type}>,",
    "after_ctx": [
      "}",
      "",
      "pub type CtxOp = Box<dyn FnMut(&mut Ctx) -> Result<(), OpError>>;",
      "",
      "// ---- signature classes (one element type per operation array) ----"
    ],
    "alias_param": "${type}",
    "alias_ret": " -> ${type}",
    "alias_ret_unit": "",
    "sig_alias": [
      "// ${sig_id}",
      "pub type ${alias} = Box<dyn Fn(${params})${ret}>;"
    ],
    "after_aliases": [
      ""
    ],
    "doc_suffix": " — ${doc}",
    "item_doc": "${indent}/// [${ordinal}] ${address} (${file}:${start}-${end}, ${language}, ${state}→${trait})${docsuffix}",
    "item_doc_internal": "${indent}// [${ordinal}] ${address} (${file}:${start}-${end}, ${language}, ${state}→${trait})${docsuffix}",
    "internal_note": [
      "${indent}// internal item (${kind}) — not generated as a free fn"
    ],
    "receiver_param": "recv: &mut serde_json::Value",
    "param": "${ident}: ${type}",
    "skeleton_ret": " -> ${type}",
    "skeleton_ret_unit": "",
    "skeleton_open": "${indent}pub fn ${name}(${params})${ret} {",
    "skeleton_body": [
      "${indent}    todo!()"
    ],
    "skeleton_close": "${indent}}",
    "wrapper_open": [
      "",
      "${indent}pub fn ${name}_op() -> crate::CtxOp {",
      "${indent}    Box::new(move |__ctx: &mut crate::Ctx| {"
    ],
    "fetch_required": [
      "${indent}        let ${var} = __ctx.${field}.clone().ok_or(crate::OpError::MissingCtxKey(\"${key}\"))?;"
    ],
    "fetch_optional": [
      "${indent}        let ${var} = __ctx.${field}.clone().unwrap_or_default();"
    ],
    "blank_arg": "Default::default()",
    "call": "${indent}        let ${result} = self::${name}(${args});",
    "store": "${indent}        __ctx.${rk} = Some(${result});",
    "discard": [
      "${indent}        let _ = ${result};"
    ],
    "wrapper_close": [
      "${indent}        Ok(())",
      "${indent}    })",
      "${indent}}"
    ],
    "op_ref": "crate::${mod_path}::${name}_op()",
    "module_open": "${indent}pub mod ${name} {",
    "module_close": "${indent}}",
    "arrays_header": [
      "// ---- operation groups (arrays partitioned by signature) ----"
    ],
    "array_comment": "// ${sig_id} — members: ${members}",
    "array_open": "pub fn ${name}() -> Vec<crate::CtxOp> {",
    "array_body": "    vec![${refs}]",
    "array_close": "}",
    "pipelines_header": [
      "",
      "// ---- ordered pipelines ----"
    ],
    "pipeline_skip": "// pipeline '${name}' skipped: stage(s) not generatable",
    "pipeline_open": "pub fn pipeline_${name}() -> Vec<crate::CtxOp> {",
    "pipeline_body": "    vec![${refs}]",
    "pipeline_close": "}",
    "footer": [],
    "pipeline_edge_op": "Box::new(move |__ctx: &mut crate::Ctx| { __ctx.${dst} = __ctx.${src}.clone(); Ok(()) })"
  },
  "files": [
    {
      "kind": "manifest",
      "path": "Cargo.toml",
      "lines": [
        "[package]",
        "name = \"${crate_name}\"",
        "version = \"0.1.0\"",
        "edition = \"2021\"",
        "",
        "[dependencies]",
        "serde_json = \"1\""
      ]
    },
    {
      "kind": "main",
      "path": "src/lib.rs"
    }
  ]
}
